{
  "manifest_version": 3,
  "name": "PartyCue",
  "description": "A cheerful OCR party helper that catches the now-playing label from a target YouTube radio stream and opens NetEase Cloud Music.",
  "version": "1.0.0",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_popup": "src/popup.html",
    "default_title": "PartyCue: 捕捉当前歌曲"
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "permissions": [
    "activeTab",
    "offscreen",
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://music.163.com/*",
    "https://www.youtube.com/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "vendor/*",
        "vendor/lang/*"
      ],
      "matches": [
        "https://www.youtube.com/*"
      ]
    }
  ]
}
